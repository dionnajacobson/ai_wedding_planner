{
  "mcp_servers": [
    {
      "name": "apify",
      "enabled": false,
      "transport": "streamable_http",
      "url": "https://mcp.apify.com?tools=fortuitous_pirate/wedding-vendor-scraper,get-actor-output",
      "headers": {
        "Authorization": "Bearer ${APIFY_API_TOKEN}"
      }
    },
    {
      "name": "filesystem",
      "enabled": false,
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]
    }
  ]
}
